HTTP_HOST=127.0.0.1
PORT=8080

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=app
POSTGRES_SSLMODE=disable

# Gere uma chave exclusiva com: openssl rand -base64 48
JWT_SECRET=
JWT_ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_IDLE_TTL=168h
REFRESH_TOKEN_ABSOLUTE_TTL=720h

# Opcional: se definida, sobrescreve as variáveis POSTGRES_* na API e nas migrações.
# DATABASE_URL=postgres://app:app@localhost:5432/app?sslmode=disable
